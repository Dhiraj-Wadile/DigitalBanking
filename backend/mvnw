#!/bin/sh
# Maven Wrapper startup script for UN*X systems

set -e

# Find project base directory
MAVEN_PROJECTBASEDIR="${MAVEN_BASEDIR:-$(cd "$(dirname "$0")" && pwd)}"
export MAVEN_PROJECTBASEDIR

# Maven wrapper JAR location
WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
WRAPPER_PROPERTIES="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"

# Determine Maven command
if [ -r "$WRAPPER_JAR" ]; then
    MAVEN_CMD="java $MAVEN_OPTS -jar $WRAPPER_JAR"
else
    if [ -r "$WRAPPER_PROPERTIES" ]; then
        DOWNLOAD_URL=$(grep 'distributionUrl' "$WRAPPER_PROPERTIES" | cut -d'=' -f2-)
    else
        DOWNLOAD_URL="https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/3.9.9/apache-maven-3.9.9-bin.zip"
    fi

    MAVEN_HOME="$HOME/.m2/wrapper/dists/apache-maven-3.9.9"
    if [ ! -d "$MAVEN_HOME" ]; then
        echo "Downloading Maven..."
        mkdir -p "$MAVEN_HOME"
        curl -fsSL "$DOWNLOAD_URL" -o "$MAVEN_HOME/maven.zip"
        unzip -qo "$MAVEN_HOME/maven.zip" -d "$MAVEN_HOME"
        rm -f "$MAVEN_HOME/maven.zip"
        MAVEN_HOME=$(find "$MAVEN_HOME" -name "apache-maven-*" -type d | head -1)
    fi
    MAVEN_CMD="$MAVEN_HOME/bin/mvn"
fi

exec $MAVEN_CMD "$@"
