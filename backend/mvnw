# ----------------------------------------------------------------------------
# Apache Maven Wrapper startup batch script, version 3.3.2
#
# Required ENV vars:
# JAVA_HOME - location of a JDK home dir
#
# Optional ENV vars
# MVNW_REPOURL - repo url base for downloading maven distribution
# MVNW_USERNAME/MVNW_PASSWORD - user and password for downloading maven
# MVNW_VERBOSE - true: enable verbose log; others: silence the output
# ----------------------------------------------------------------------------

set -euf
[ "${MVNW_VERBOSE-}" != debug ] || set -x

# Determine the project base directory
MVNW_PROJECTBASEDIR="${MVNW_PROJECTBASEDIR:-$(cd "$(dirname "$0")" && pwd)}"
export MVNW_PROJECTBASEDIR

# Read distribution URL from properties if not set
WRAPPER_PROPERTIES="$MVNW_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"
WRAPPER_URL="${MVNW_REPOURL:-https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.3.2/maven-wrapper-3.3.2.jar}"
DIST_URL="${DIST_URL:-https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/3.9.9/apache-maven-3.9.9-bin.zip}"

if [ -f "$WRAPPER_PROPERTIES" ]; then
    while IFS="=" read -r key value; do
        case "$key" in (wrapperUrl) WRAPPER_URL="$value";; esac
        case "$key" in (distributionUrl) DIST_URL="$value";; esac
    done < "$WRAPPER_PROPERTIES"
fi

# Check if mvn is already available
if command -v mvn > /dev/null 2>&1; then
    exec mvn "$@"
fi

WRAPPER_JAR="$MVNW_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
WRAPPER_LAUNCHER="org.apache.maven.wrapper.MavenWrapperMain"

# Download wrapper jar if not present
if [ ! -e "$WRAPPER_JAR" ]; then
    if [ "${MVNW_VERBOSE-}" = true ]; then
        echo "Downloading Maven Wrapper..."
    fi
    if command -v curl > /dev/null 2>&1; then
        curl -fsSL -o "$WRAPPER_JAR" "$WRAPPER_URL"
    elif command -v wget > /dev/null 2>&1; then
        wget -q -O "$WRAPPER_JAR" "$WRAPPER_URL"
    else
        echo "Error: Neither curl nor wget found. Cannot download Maven Wrapper." >&2
        exit 1
    fi
fi

# Run the wrapper
exec java $MAVEN_OPTS \
    -classpath "$WRAPPER_JAR" \
    "-Dmaven.multiModuleProjectDirectory=$MVNW_PROJECTBASEDIR" \
    "$WRAPPER_LAUNCHER" "$@"
